# Azure IoT Hub Registry Credentials
IOT_HUB_NAME=iot63127728.azure-devices.net
IOT_DEVICE_ID=device1

# Networking Parameters
OPC_MULTICAST_URL=224.0.0.22:4840
CERT_VOLUME_PATH=./certs

# Container Core Configurations
SSL_CERT_FILE=/etc/ssl/opc-gateway/device.crt
SSL_KEY_FILE=/etc/ssl/opc-gateway/device.key
LD_LIBRARY_PATH=/usr/local/lib

# Cosmos DB Configuration
COSMOS_URI=
COSMOS_KEY=